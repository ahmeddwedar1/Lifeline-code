{
  "openapi": "3.0.3",
  "info": {
    "title": "LifeLine API",
    "description": "Emergency Medical Resource Management Platform API",
    "version": "1.0.0",
    "contact": {
      "email": "admin@lifeline.com"
    }
  },
  "servers": [
    { "url": "http://localhost:5000", "description": "Development server" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string" },
          "errors": { "type": "array", "items": { "type": "object" } }
        }
      },
      "Success": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "type": "object" },
          "message": { "type": "string" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8 }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password", "fullName"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8 },
          "fullName": { "type": "string", "minLength": 2 },
          "phone": { "type": "string" },
          "role": { "type": "string", "enum": ["PUBLIC_USER", "DOCTOR", "HOSPITAL", "AMBULANCE"] },
          "hospitalId": { "type": "string", "format": "uuid" }
        }
      },
      "EmergencyRequest": {
        "type": "object",
        "required": ["symptoms"],
        "properties": {
          "patientName": { "type": "string" },
          "patientAge": { "type": "integer" },
          "symptoms": { "type": "string" },
          "locationAddress": { "type": "string" },
          "latitude": { "type": "number", "format": "float" },
          "longitude": { "type": "number", "format": "float" }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health check",
        "tags": ["System"],
        "responses": {
          "200": { "description": "API is healthy" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register new user",
        "tags": ["Authentication"],
        "requestBody": { "$ref": "#/components/requestBodies/RegisterRequest" },
        "responses": {
          "201": { "description": "User registered successfully" },
          "409": { "description": "Email already registered" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login user",
        "tags": ["Authentication"],
        "requestBody": { "$ref": "#/components/requestBodies/LoginRequest" },
        "responses": {
          "200": { "description": "Login successful" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Logout user",
        "tags": ["Authentication"],
        "responses": { "200": { "description": "Logged out" } }
      }
    },
    "/api/auth/refresh-token": {
      "post": {
        "summary": "Refresh access token",
        "tags": ["Authentication"],
        "responses": { "200": { "description": "New token issued" } }
      }
    },
    "/api/auth/verify-email": {
      "post": {
        "summary": "Verify email with OTP",
        "tags": ["Authentication"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "otp": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Email verified" } }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Get current user profile",
        "tags": ["Authentication"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "User profile" } }
      }
    },
    "/api/emergency": {
      "post": {
        "summary": "Submit emergency report",
        "tags": ["Emergency"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/EmergencyRequest" },
        "responses": { "201": { "description": "Emergency reported" } }
      },
      "get": {
        "summary": "Get all emergencies",
        "tags": ["Emergency"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "severity", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "List of emergencies" } }
      }
    },
    "/api/search/hospitals": {
      "get": {
        "summary": "Search hospitals",
        "tags": ["Search"],
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" } },
          { "name": "city", "in": "query", "schema": { "type": "string" } },
          { "name": "specialization", "in": "query", "schema": { "type": "string" } },
          { "name": "hasBlood", "in": "query", "schema": { "type": "boolean" } },
          { "name": "bloodType", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Hospital search results" } }
      }
    },
    "/api/blood/stock": {
      "get": {
        "summary": "Get blood stock availability",
        "tags": ["Blood Bank"],
        "responses": { "200": { "description": "Blood stock data" } }
      }
    },
    "/api/notifications": {
      "get": {
        "summary": "Get user notifications",
        "tags": ["Notifications"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "User notifications" } }
      }
    },
    "/api/admin/stats": {
      "get": {
        "summary": "Get system statistics",
        "tags": ["Admin"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "System stats" } }
      }
    }
  }
}
